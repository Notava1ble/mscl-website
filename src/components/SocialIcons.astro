---
import Default from "@astrojs/starlight/components/SocialIcons.astro"
---

<div class="custom-header-container">
  <div class="custom-social-icons">
    <a href="/" title="Home" class="home-icon">
      <svg fill="currentColor" viewBox="0 0 24 24" width="16" height="16">
        <path
          d="M11.47 3.841a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.061l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 101.061 1.06l8.69-8.689z"
        ></path>
        <path
          d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.432z"
        ></path>
      </svg>
    </a>
    <Default><slot /></Default>
  </div>
</div>

<style>
  .custom-header-container {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .custom-header-links {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .custom-header-links a {
    text-decoration: none;
    color: var(--sl-color-white);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .custom-header-links a:hover {
    color: var(--sl-color-text-accent);
  }

  .theme-divider {
    display: none;
  }

  .custom-social-icons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .home-icon {
    display: flex;
    align-items: center;
    color: var(--sl-color-text-accent);
    opacity: 0.8;
  }

  .home-icon:hover {
    opacity: 1;
  }

  @media (max-width: 50rem) {
    .custom-header-links {
      display: none;
    }
  }
</style>
